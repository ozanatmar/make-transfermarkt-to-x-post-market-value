        {
            "id": 52,
            "module": "code:ExecuteCode",
            "version": 1,
            "parameters": {},
            "mapper": {
                "language": "javascript",
                "input": [
                    {
                        "name": "html",
                        "value": "{{57.data}}"
                    },
                    {
                        "name": "leagueEmoji",
                        "value": "🏴󠁧󠁢󠁥󠁮󠁧󠁿"
                    }
                ],
                "dependencies": [],
                "inputFormat": "editor",
                "codeEditorJavascript": "const html = input.html;\nconst emoji = input.leagueEmoji;\n\nconst tableStart = html.indexOf('id=\"yw1\"');\nconst tableEnd = html.indexOf('id=\"yw2\"');\nconst tableHtml = html.substring(tableStart, tableEnd);\n\nconsole.log('tableHtml length:', tableHtml.length);\nconsole.log('tableHtml sample:', tableHtml.substring(0, 500));\n\nconst nameRegex = /<a title=\"([^\"]+)\" href=\"\\/[^\"]+\\/profil\\/spieler\\/\\d+\"/g;\nconst valueRegex = /marktwertverlauf\\/spieler\\/\\d+\">([^<]+)<\\/a>/g;\nconst clubRegex = /<td class=\"zentriert\"><a title=\"([^\"]+)\" href=\"\\/[^\"]+\\/startseite\\/verein/g;\n\nconst names = [...tableHtml.matchAll(nameRegex)].map(m => m[1]);\nconst values = [...tableHtml.matchAll(valueRegex)].map(m => m[1].trim());\nconst clubs = [...tableHtml.matchAll(clubRegex)].map(m => m[1]);\n\nconsole.log('names found:', names.length, names.slice(0, 3));\nconsole.log('values found:', values.length, values.slice(0, 3));\nconsole.log('clubs found:', clubs.length, clubs.slice(0, 3));\n\nconst players = [];\nfor (let i = 0; i < Math.min(10, names.length); i++) {\n  players.push({\n    name: names[i],\n    club: clubs[i] || '',\n    value: (values[i] || '').trim().replace('.00m', 'm')\n  });\n}\n\nconst leagueMatch = html.match(/Top market values ([^<]+)<\\/h1>/);\nconst leagueName = leagueMatch ? leagueMatch[1].trim() : 'League';\n\nconsole.log('leagueName:', leagueName);\nconsole.log('players:', JSON.stringify(players.slice(0, 3)));\n\nconst lines = players\n  .map((p, i) => `${i + 1}. ${p.name} (${p.club}) – ${p.value}`)\n  .join('\\\\n');\n\nconst tweet = `${emoji} ${leagueName} – Most Valuable Players\\\\n\\\\n${lines}\\\\n\\\\nWho's the most valuable player in your league? 👇`;\n\nreturn { tweet };"
            },
            "metadata": {
                "designer": {
                    "x": 600,
                    "y": 0
                },
